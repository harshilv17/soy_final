{{ 'section-ds-about-us-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --ds-about-min-height: {{ section.settings.min_height }}vh;
  }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="ds-about-us-hero color-{{ section.settings.color_scheme }} gradient">
  <div
    class="ds-about-us-hero__bg"
    {% if section.settings.image != blank %}
      style="background-image: url('{{ section.settings.image | image_url: width: 2800 }}');"
    {% endif %}
  ></div>
  {%- if section.settings.image != blank and section.settings.overlay_opacity > 0 -%}
    <div
      class="ds-about-us-hero__overlay"
      style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
    ></div>
  {%- endif -%}

  <div class="page-width section-{{ section.id }}-padding ds-about-us-hero__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="ds-about-us-hero__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <div class="ds-about-us-hero__subtext rte">{{ section.settings.subtext }}</div>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a
        href="{% if section.settings.button_link != blank %}{{ section.settings.button_link }}{% else %}#{% endif %}"
        class="ds-about-us-hero__btn"
      >
        {{- section.settings.button_label | escape -}}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "About hero",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Optional. Add your texture or photo; section works with a soft cream fallback until an image is set."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 85,
      "step": 5,
      "unit": "%",
      "label": "Cream overlay on image",
      "info": "Improves text readability over busy photos. 0 = no overlay.",
      "default": 35
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 35,
      "max": 85,
      "step": 5,
      "unit": "vh",
      "label": "Minimum section height",
      "default": 55
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WELCOME TO OUR WORLD"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Text",
      "default": "<p>We're a brand born from a little madness, held together by craft, and fueled by feeling.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "ABOUT US"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "accent-1", "label": "t:sections.all.colors.accent_1.label" },
        { "value": "accent-2", "label": "t:sections.all.colors.accent_2.label" },
        { "value": "background-1", "label": "t:sections.all.colors.background_1.label" },
        { "value": "background-2", "label": "t:sections.all.colors.background_2.label" },
        { "value": "inverse", "label": "t:sections.all.colors.inverse.label" }
      ],
      "default": "background-1",
      "label": "t:sections.all.colors.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "About hero"
    }
  ]
}
{% endschema %}
