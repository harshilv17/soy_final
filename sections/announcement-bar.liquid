{%- for block in section.blocks -%}
  {%- case block.type -%}
    {%- when 'announcement' -%}
      <div
        class="announcement-bar color-{{ block.settings.color_scheme }} gradient"
        role="region"
        aria-label="{{ 'sections.header.announcement' | t }}"
        style="
          --ab-height: {{ section.settings.bar_height }}px;
          --ab-font-size: {{ section.settings.font_size }}px;
          --ab-letter-spacing: {{ section.settings.letter_spacing }}em;
          --ab-font-weight: {{ section.settings.font_weight }};
          --ab-text-transform: {{ section.settings.text_transform }};
        "
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.text != blank -%}
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="announcement-bar__link link link--text focus-inset animate-arrow">
          {%- endif -%}
              <div class="page-width">
                <p class="announcement-bar__message announcement-bar__text {{ block.settings.text_alignment }} h5">
                  <span class="announcement-bar__text-inner">{{ block.settings.text | escape }}</span>
                  {%- if block.settings.link != blank -%}
                    {% render 'icon-arrow' %}
                  {%- endif -%}
                </p>
              </div>
          {%- if block.settings.link != blank -%}
            </a>
          {%- endif -%}
        {%- endif -%}
      </div>
  {%- endcase -%}
{%- endfor -%}

{% stylesheet %}
  .announcement-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: var(--ab-height, 34px);
    padding-block: 0;
    border-block-end: 1px solid rgba(var(--color-foreground), 0.12);
  }

  .announcement-bar .page-width {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100%;
  }

  .announcement-bar .announcement-bar__link {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: var(--ab-height, 34px);
    width: 100%;
    text-decoration: none;
  }

  .announcement-bar .announcement-bar__text,
  .announcement-bar .announcement-bar__message {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: var(--ab-height, 34px);
    font-family: var(--font-body--family);
    font-size: var(--ab-font-size, var(--announcement-bar-font-size));
    font-weight: var(--ab-font-weight, 400);
    letter-spacing: var(--ab-letter-spacing, var(--announcement-bar-letter-spacing));
    text-transform: var(--ab-text-transform, uppercase);
    color: rgb(var(--color-foreground));
    margin: 0;
    width: 100%;
    text-align: center;
  }

  .announcement-bar .announcement-bar__message.h5 {
    font-size: var(--ab-font-size, var(--announcement-bar-font-size));
    line-height: 1.2;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "max_blocks": 12,
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "range",
      "id": "bar_height",
      "min": 22,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Bar height",
      "default": 34
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "default": "400",
      "options": [
        { "value": "400", "label": "Regular (400)" },
        { "value": "500", "label": "Medium (500)" },
        { "value": "600", "label": "Semi-bold (600)" }
      ]
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": 0,
      "max": 0.2,
      "step": 0.1,
      "label": "Letter spacing",
      "default": 0.1
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text transform",
      "default": "uppercase",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "UPPERCASE" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement-bar.blocks.announcement.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Welcome to our store",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text.label"
        },
        {
          "type": "select",
          "id": "text_alignment",
          "options": [
            {
              "value": "left",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.text_alignment.options__1.label"
            },
            {
              "value": "center",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.text_alignment.options__2.label"
            },
            {
              "value": "right",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.text_alignment.options__3.label"
            }
          ],
          "default": "center",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text_alignment.label"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "t:sections.all.colors.label",
          "default": "scheme-4"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.link.label"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "announcement"
      }
    ]
  }
}
{% endschema %}
