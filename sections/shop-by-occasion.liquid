{{ 'section-shop-by-occasion.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign wrap_class = 'shop-by-occasion color-' | append: section.settings.color_scheme | append: ' gradient'
  if section.settings.section_width == 'full-width'
    assign wrap_class = wrap_class | append: ' shop-by-occasion--full-width'
  endif
-%}

<div class="{{ wrap_class }} section-{{ section.id }}-padding">
  <div class="shop-by-occasion__inner{% if section.settings.section_width == 'page-width' %} page-width{% endif %}">
    <h2 class="shop-by-occasion__heading">{{ section.settings.title | escape }}</h2>

    <div class="shop-by-occasion__grid" role="list">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'tile' -%}
            {%- assign tile_href = block.settings.link | default: routes.collections_url -%}
            {%- if block.settings.image != blank -%}
              {%- assign tile_alt = block.settings.image.alt | default: block.settings.label -%}
            {%- else -%}
              {%- assign tile_alt = block.settings.label -%}
            {%- endif -%}
            <div class="shop-by-occasion__tile" role="listitem" {{ block.shopify_attributes }}>
              <a class="shop-by-occasion__tile-link" href="{{ tile_href }}">
                <div class="shop-by-occasion__tile-media">
                  {%- if block.settings.image != blank -%}
                    {{
                      block.settings.image
                      | image_url: width: 900
                      | image_tag:
                        loading: 'lazy',
                        widths: '200, 400, 600, 900',
                        sizes: '(min-width: 990px) 22vw, 45vw',
                        class: 'shop-by-occasion__image',
                        alt: tile_alt
                    }}
                  {%- else -%}
                    {{ 'collection-apparel-1' | placeholder_svg_tag: 'shop-by-occasion__placeholder' }}
                  {%- endif -%}
                  <div class="shop-by-occasion__tile-gradient" aria-hidden="true"></div>
                </div>
                <span class="shop-by-occasion__tile-label">{{ block.settings.label | escape }}</span>
              </a>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Shop by occasion",
  "tag": "section",
  "class": "section-wrapper",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by occasion"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.all.padding.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.all.padding.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Occasion"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by occasion",
      "blocks": [
        {
          "type": "tile",
          "settings": {
            "label": "Work day wear"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "Festive season"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "Weekend easy"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "Gift with love"
          }
        }
      ]
    }
  ]
}
{% endschema %}
